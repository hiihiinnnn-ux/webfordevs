# Server configuration
PORT=4000

# Comma-separated list of allowed CORS origins for the frontend
CLIENT_ORIGIN=http://localhost:5173

# Secret used to sign JWT access tokens. CHANGE THIS in production.
JWT_SECRET=change-me-in-production-a-long-random-string

# How long an access token stays valid
JWT_EXPIRES_IN=7d

# Path to the SQLite database file (relative to server/)
DATABASE_PATH=./data/localai-hub.db
