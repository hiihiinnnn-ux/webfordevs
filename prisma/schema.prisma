generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id           String     @id @default(cuid())
  email        String     @unique
  username     String     @unique
  passwordHash String
  displayName  String?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  favorites    Favorite[]
}

model AiModel {
  id            String   @id @default(cuid())
  slug          String   @unique
  name          String
  vendor        String
  description   String
  sizeParams    String?
  license       String?
  contextLength Int?
  tags          String
  hardwareMin   String?
  ollamaName    String?
  hfUrl         String?
  useCases      String
  createdAt     DateTime @default(now())
}

model Tool {
  id          String   @id @default(cuid())
  slug        String   @unique
  name        String
  category    String
  description String
  website     String?
  github      String?
  platforms   String
  tags        String
  difficulty  String
  createdAt   DateTime @default(now())
}

model Guide {
  id          String   @id @default(cuid())
  slug        String   @unique
  title       String
  summary     String
  content     String
  level       String
  sortOrder   Int      @default(0)
  readingMins Int      @default(5)
  createdAt   DateTime @default(now())
}

model Favorite {
  id        String   @id @default(cuid())
  userId    String
  itemType  String
  itemId    String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, itemType, itemId])
  @@index([userId])
  @@index([itemType, itemId])
}
